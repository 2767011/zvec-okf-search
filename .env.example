OKF_ZVEC_HOME=/opt/okf-zvec-search
OKF_ZVEC_TOKEN_FILE=/opt/okf-zvec-search/config/service-token
OKF_ZVEC_SEARCH_TOKEN_FILE=/opt/okf-zvec-search/config/search-token
OKF_ZVEC_ADMIN_TOKEN_FILE=/opt/okf-zvec-search/config/admin-token
# OKF_ZVEC_ALLOW_ANONYMOUS_SEARCH=0
HF_HOME=/opt/okf-zvec-search/data/huggingface
OKF_ZVEC_RUNTIME_SETTINGS_FILE=/opt/okf-zvec-search/config/runtime-settings.json
OKF_ZVEC_AI_HISTORY_FILE=/opt/okf-zvec-search/config/ai-search-history.json
OKF_ZVEC_ACTIVE_DB_FILE=/opt/okf-zvec-search/data/active-db-root
OKF_ZVEC_KEEP_VERSIONS=3
OKF_ZVEC_SEMANTIC_WEIGHT=1
OKF_ZVEC_FTS_WEIGHT=1
OKF_ZVEC_MIN_RELEVANCE=0.25
OKF_ZVEC_PRELOAD_MODELS=e5
OKF_ZVEC_INDEX_MODELS=e5
OKF_ZVEC_MAX_SYNC_BYTES=104857600
OKF_ZVEC_MAX_EXTRACTED_BYTES=524288000
OKF_ZVEC_MAX_ARCHIVE_MEMBERS=10000
OKF_ZVEC_INDEX_BATCH_SIZE=256
# HF_TOKEN=
